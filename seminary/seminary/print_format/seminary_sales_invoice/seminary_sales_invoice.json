 "font_size": 14,
 "html": "<div class=\"seminary-invoice\">\n  <style>\n    .seminary-invoice { font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, sans-serif; color: #1f2937; }\n    .seminary-invoice .header { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 24px; padding-bottom: 12px; border-bottom: 2px solid #1f2937; }\n    .seminary-invoice .header h1 { margin: 0; font-size: 22px; }\n    .seminary-invoice .header .meta { text-align: right; font-size: 13px; }\n    .seminary-invoice .header .meta strong { display: inline-block; min-width: 70px; }\n    .seminary-invoice .summary { font-size: 16px; font-weight: 600; margin: 16px 0 4px 0; }\n    .seminary-invoice .parties { display: flex; gap: 32px; margin-bottom: 20px; font-size: 13px; }\n    .seminary-invoice .parties .col { flex: 1; }\n    .seminary-invoice .parties .label { color: #6b7280; text-transform: uppercase; font-size: 11px; letter-spacing: 0.4px; }\n    .seminary-invoice table { width: 100%; border-collapse: collapse; font-size: 13px; }\n    .seminary-invoice table.lines th { text-align: left; padding: 8px; background: #f3f4f6; border-bottom: 1px solid #d1d5db; }\n    .seminary-invoice table.lines td { padding: 8px; border-bottom: 1px solid #e5e7eb; vertical-align: top; }\n    .seminary-invoice table.lines td.num, .seminary-invoice table.lines th.num { text-align: right; white-space: nowrap; }\n    .seminary-invoice .totals { margin-top: 12px; margin-left: auto; width: 280px; font-size: 13px; }\n    .seminary-invoice .totals tr td { padding: 4px 8px; }\n    .seminary-invoice .totals tr.grand td { font-weight: 700; font-size: 15px; border-top: 2px solid #1f2937; padding-top: 8px; }\n    .seminary-invoice .schedule { margin-top: 24px; }\n    .seminary-invoice .schedule h4 { margin: 0 0 6px 0; font-size: 13px; color: #6b7280; text-transform: uppercase; letter-spacing: 0.4px; }\n    .seminary-invoice .footer { margin-top: 36px; padding-top: 12px; border-top: 1px solid #e5e7eb; font-size: 12px; color: #6b7280; text-align: center; }\n  </style>\n\n  <div class=\"header\">\n    <div>\n      <h1>{{ doc.company }}</h1>\n      <div style=\"font-size: 13px; color: #6b7280;\">{{ _(\"Sales Invoice\") }} \u00b7 {{ doc.name }}</div>\n    </div>\n    <div class=\"meta\">\n      <div><strong>{{ _(\"Date\") }}:</strong> {{ frappe.utils.formatdate(doc.posting_date) }}</div>\n      {% if doc.due_date %}<div><strong>{{ _(\"Due\") }}:</strong> {{ frappe.utils.formatdate(doc.due_date) }}</div>{% endif %}\n      <div><strong>{{ _(\"Status\") }}:</strong> {{ doc.status }}</div>\n    </div>\n  </div>\n\n  {% if doc.seminary_summary %}<div class=\"summary\">{{ doc.seminary_summary }}</div>{% endif %}\n\n  <div class=\"parties\">\n    <div class=\"col\">\n      <div class=\"label\">{{ _(\"Billed to\") }}</div>\n      <div>{{ doc.customer_name or doc.customer }}</div>\n    </div>\n    {% if doc.custom_student %}\n    {% set student_name = frappe.db.get_value(\"Student\", doc.custom_student, \"student_name\") %}\n    <div class=\"col\">\n      <div class=\"label\">{{ _(\"Student\") }}</div>\n      <div>{{ student_name or doc.custom_student }}</div>\n      <div style=\"color: #6b7280; font-size: 12px;\">{{ doc.custom_student }}</div>\n    </div>\n    {% endif %}\n  </div>\n\n  <table class=\"lines\">\n    <thead>\n      <tr>\n        <th>{{ _(\"Description\") }}</th>\n        <th class=\"num\">{{ _(\"Qty\") }}</th>\n        <th class=\"num\">{{ _(\"Rate\") }}</th>\n        <th class=\"num\">{{ _(\"Amount\") }}</th>\n      </tr>\n    </thead>\n    <tbody>\n      {% for item in doc.items %}\n      <tr>\n        <td>{{ item.description or item.item_name }}</td>\n        <td class=\"num\">{{ item.qty }} {{ item.uom or '' }}</td>\n        <td class=\"num\">{{ frappe.utils.fmt_money(item.rate, currency=doc.currency) }}</td>\n        <td class=\"num\">{{ frappe.utils.fmt_money(item.amount, currency=doc.currency) }}</td>\n      </tr>\n      {% endfor %}\n    </tbody>\n  </table>\n\n  <table class=\"totals\">\n    {% if doc.discount_amount %}\n    <tr><td>{{ _(\"Subtotal\") }}</td><td class=\"num\" align=\"right\">{{ frappe.utils.fmt_money(doc.net_total, currency=doc.currency) }}</td></tr>\n    <tr><td>{{ _(\"Discount\") }}</td><td class=\"num\" align=\"right\">-{{ frappe.utils.fmt_money(doc.discount_amount, currency=doc.currency) }}</td></tr>\n    {% endif %}\n    <tr class=\"grand\"><td>{{ _(\"Total\") }}</td><td class=\"num\" align=\"right\">{{ frappe.utils.fmt_money(doc.grand_total, currency=doc.currency) }}</td></tr>\n    {% if doc.outstanding_amount and doc.outstanding_amount != doc.grand_total %}\n    <tr><td>{{ _(\"Outstanding\") }}</td><td class=\"num\" align=\"right\">{{ frappe.utils.fmt_money(doc.outstanding_amount, currency=doc.currency) }}</td></tr>\n    {% endif %}\n  </table>\n\n  {% if doc.payment_schedule %}\n  <div class=\"schedule\">\n    <h4>{{ _(\"Payment Schedule\") }}</h4>\n    <table class=\"lines\">\n      <thead>\n        <tr><th>{{ _(\"Due Date\") }}</th><th>{{ _(\"Description\") }}</th><th class=\"num\">{{ _(\"Amount\") }}</th></tr>\n      </thead>\n      <tbody>\n        {% for ps in doc.payment_schedule %}\n        <tr>\n          <td>{{ frappe.utils.formatdate(ps.due_date) }}</td>\n          <td>{{ ps.description or ps.payment_term or '' }}</td>\n          <td class=\"num\">{{ frappe.utils.fmt_money(ps.payment_amount, currency=doc.currency) }}</td>\n        </tr>\n        {% endfor %}\n      </tbody>\n    </table>\n  </div>\n  {% endif %}\n\n  <div class=\"footer\">{{ _(\"Thank you.\") }}</div>\n</div>",
