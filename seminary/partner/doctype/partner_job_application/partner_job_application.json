   "fieldname": "doctrinal_alignment",
   "fieldtype": "Select",
   "label": "Doctrinal Alignment",
   "options": "\nI agree completely, without reservations\nI agree completely, with reservations\nI agree partially\nI disagree"
  },
  {
   "depends_on": "eval:doc.doctrinal_alignment && doc.doctrinal_alignment != 'I agree completely, without reservations'",
