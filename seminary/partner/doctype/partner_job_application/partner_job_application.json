   "fieldtype": "Data",
   "label": "Mobile",
   "options": "Phone",
   "read_only": 1
  },
  {
   "fieldname": "submission_section",
   "fieldtype": "Section Break",
   "label": "Submission"
  },
  {
   "fieldname": "cover_letter",
   "fieldtype": "Text Editor",
   "label": "Cover Letter"
  },
  {
